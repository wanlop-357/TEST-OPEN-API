{
  "name": "test-open-api",
  "version": "0.1.0",
  "description": "NestJS API with OpenAPI documentation prepared for ApiDoc.io publishing.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\"",
    "prepare": "husky",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "ESLINT_USE_FLAT_CONFIG=false eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "openapi:json": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi.ts json",
    "openapi:yaml": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi.ts yaml",
    "openapi:generate": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi.ts generate",
    "openapi:validate": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi.ts validate",
    "openapi:diff": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi.ts diff",
    "openapi:watch": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi.ts watch",
    "apidoc:prepare": "npm run openapi:generate && node scripts/apidoc-prepare.js",
    "predeploy": "bash scripts/predeploy.sh"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@sentry/nestjs": "^8.47.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "source-map-support": "^0.5.21",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "chokidar": "^3.6.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*(\\.|-)spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "ESLINT_USE_FLAT_CONFIG=false eslint --fix",
      "prettier --write"
    ],
    "test/**/*.ts": [
      "ESLINT_USE_FLAT_CONFIG=false eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
